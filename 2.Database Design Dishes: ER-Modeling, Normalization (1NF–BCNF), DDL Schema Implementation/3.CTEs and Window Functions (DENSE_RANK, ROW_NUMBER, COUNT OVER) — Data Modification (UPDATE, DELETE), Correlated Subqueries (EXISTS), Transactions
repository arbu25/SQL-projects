BEGIN;

DROP TABLE IF EXISTS public.dishes_instruments CASCADE;
DROP TABLE IF EXISTS public.dishes_ingridients CASCADE;
DROP TABLE IF EXISTS public.category_dishes CASCADE;
DROP TABLE IF EXISTS public.unit_transformation CASCADE;
DROP TABLE IF EXISTS public.instruments CASCADE;
DROP TABLE IF EXISTS public.dishes CASCADE;
DROP TABLE IF EXISTS public.ingridients CASCADE;
DROP TABLE IF EXISTS public.standard_units CASCADE;
DROP TABLE IF EXISTS public.category CASCADE;


CREATE TABLE IF NOT EXISTS public.category
(
    category_id integer,
    name character varying,
    parent_id integer,
    v_order integer,
    h_order integer,
    PRIMARY KEY (category_id),
    CONSTRAINT category_name_unique UNIQUE (name),
    CONSTRAINT category_parent_fk FOREIGN KEY (parent_id)
        REFERENCES public.category (category_id)
);


CREATE TABLE IF NOT EXISTS public.standard_units
(
    unit_id integer,
    unit_namr character varying,
    is_standart boolean DEFAULT TRUE,
    PRIMARY KEY (unit_id),
    CONSTRAINT standard_units_unit_name_unique UNIQUE (unit_namr)
);


CREATE TABLE IF NOT EXISTS public.ingridients
(
    ingridient_id integer,
    short_description text,
    unit_id integer,
    PRIMARY KEY (ingridient_id),
    CONSTRAINT ingridients_description_unique UNIQUE (short_description),
    CONSTRAINT ingridients_unit_fk FOREIGN KEY (unit_id)
        REFERENCES public.standard_units (unit_id)
);


CREATE TABLE IF NOT EXISTS public.dishes
(
    dish_id integer,
    name character varying,
    prep_time interval,
    instructions text,
    category_id integer,
    PRIMARY KEY (dish_id),
    CONSTRAINT dishes_name_unique UNIQUE (name),
    CONSTRAINT dishes_category_fk FOREIGN KEY (category_id)
        REFERENCES public.category (category_id)
);


CREATE TABLE IF NOT EXISTS public.unit_transformation
(
    transformation_id integer,
    ingredient_id integer,
    non_standard_name integer,
    standart_amount numeric,
    standard_unit integer,
    PRIMARY KEY (transformation_id),
    CONSTRAINT unit_transformation_unique UNIQUE 
        (ingredient_id, non_standard_name, standard_unit),
    CONSTRAINT unit_transformation_non_standard_fk FOREIGN KEY (non_standard_name)
        REFERENCES public.standard_units (unit_id),
    CONSTRAINT unit_transformation_standard_fk FOREIGN KEY (standard_unit)
        REFERENCES public.standard_units (unit_id),
    CONSTRAINT unit_transformation_ingredient_fk FOREIGN KEY (ingredient_id)
        REFERENCES public.ingridients (ingridient_id)
);


CREATE TABLE IF NOT EXISTS public.instruments
(
    id integer,
    name character varying,
    dishes_id integer,
    PRIMARY KEY (id),
    CONSTRAINT instruments_name_unique UNIQUE (name),
    CONSTRAINT instruments_dishes_fk FOREIGN KEY (dishes_id)
        REFERENCES public.dishes (dish_id)
);


CREATE TABLE IF NOT EXISTS public.category_dishes
(
    category_category_id integer,
    dishes_dish_id integer,
    PRIMARY KEY (category_category_id, dishes_dish_id),
    CONSTRAINT category_dishes_category_fk FOREIGN KEY (category_category_id)
        REFERENCES public.category (category_id),
    CONSTRAINT category_dishes_dishes_fk FOREIGN KEY (dishes_dish_id)
        REFERENCES public.dishes (dish_id)
);


CREATE TABLE IF NOT EXISTS public.dishes_ingridients
(
    dishes_dish_id integer,
    ingridients_ingridient_id integer,
    amount integer,
    PRIMARY KEY (dishes_dish_id, ingridients_ingridient_id),
    CONSTRAINT dishes_ingridients_dishes_fk FOREIGN KEY (dishes_dish_id)
        REFERENCES public.dishes (dish_id),
    CONSTRAINT dishes_ingridients_ingridients_fk FOREIGN KEY (ingridients_ingridient_id)
        REFERENCES public.ingridients (ingridient_id)
);


CREATE TABLE IF NOT EXISTS public.dishes_instruments
(
    dishes_dish_id integer,
    instruments_id integer,
    PRIMARY KEY (dishes_dish_id, instruments_id),
    CONSTRAINT dishes_instruments_dishes_fk FOREIGN KEY (dishes_dish_id)
        REFERENCES public.dishes (dish_id),
    CONSTRAINT dishes_instruments_instruments_fk FOREIGN KEY (instruments_id)
        REFERENCES public.instruments (id)
);


