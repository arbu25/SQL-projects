BEGIN;

WITH teaspoon_ingredients AS (
    SELECT i.ingridient_id
    FROM public.ingridients i
    JOIN public.standard_units su
        ON su.unit_id = i.unit_id
    WHERE LOWER(su.unit_namr) = LOWER('чайная ложка')
)
UPDATE public.dishes_ingridients di
SET amount = amount * 8
FROM teaspoon_ingredients ti
WHERE di.ingridients_ingridient_id = ti.ingridient_id;


UPDATE public.ingridients i
SET unit_id = (
    SELECT su_gram.unit_id
    FROM public.standard_units su_gram
    WHERE LOWER(su_gram.unit_namr) = LOWER('грамм')
    LIMIT 1
)
WHERE i.unit_id = (
    SELECT su_spoon.unit_id
    FROM public.standard_units su_spoon
    WHERE LOWER(su_spoon.unit_namr) = LOWER('чайная ложка')
    LIMIT 1
)
AND EXISTS (
    SELECT 1
    FROM public.dishes_ingridients di
    WHERE di.ingridients_ingridient_id = i.ingridient_id
);

COMMIT;

--5

WITH recipe_items AS (
    SELECT DISTINCT
        d.dish_id,
        d.name AS dish_name,
        i.ingridient_id,
        i.short_description AS ingredient_name
    FROM public.dishes d
    JOIN public.dishes_ingridients di
        ON d.dish_id = di.dishes_dish_id
    JOIN public.ingridients i
        ON i.ingridient_id = di.ingridients_ingridient_id
)
SELECT
    dish_name,
    ingredient_name,
    COUNT(*) OVER (
        PARTITION BY ingridient_id
    ) AS ingredient_count_in_all_recipes,
    COUNT(*) OVER (
        PARTITION BY dish_id
    ) AS ingredients_count_in_dish
FROM recipe_items
ORDER BY dish_name, ingredient_name;

--6

SELECT
    c.name AS category_name,
    d.name AS dish_name,
    ROW_NUMBER() OVER (
        PARTITION BY c.category_id, d.dish_id
        ORDER BY i.short_description
    ) AS ingredient_number,
    i.short_description AS ingredient_name,
    di.amount
FROM public.category c
JOIN public.category_dishes cd
    ON c.category_id = cd.category_category_id
JOIN public.dishes d
    ON d.dish_id = cd.dishes_dish_id
JOIN public.dishes_ingridients di
    ON d.dish_id = di.dishes_dish_id
JOIN public.ingridients i
    ON i.ingridient_id = di.ingridients_ingridient_id
ORDER BY
    c.name,
    d.name,
    i.short_description;
