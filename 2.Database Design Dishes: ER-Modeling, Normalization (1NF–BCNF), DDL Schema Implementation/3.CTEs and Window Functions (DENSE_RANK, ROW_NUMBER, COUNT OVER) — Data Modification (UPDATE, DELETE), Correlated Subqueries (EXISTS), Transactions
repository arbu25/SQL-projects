-- 0
WITH ingredient_usage AS (
    SELECT
        i.short_description AS ingredient_name,
        COUNT(DISTINCT di.dishes_dish_id) AS dish_count,
        DENSE_RANK() OVER (
            ORDER BY COUNT(DISTINCT di.dishes_dish_id) DESC
        ) AS rnk
    FROM public.ingridients i
    JOIN public.dishes_ingridients di
        ON i.ingridient_id = di.ingridients_ingridient_id
    GROUP BY i.ingridient_id, i.short_description
)
SELECT ingredient_name
FROM ingredient_usage
WHERE rnk = 1;

-- 1
WITH dish_weight AS (
    SELECT
        d.name AS dish_name,
        SUM(di.amount) AS total_weight,
        DENSE_RANK() OVER (
            ORDER BY SUM(di.amount) DESC
        ) AS rnk
    FROM public.dishes d
    JOIN public.dishes_ingridients di
        ON d.dish_id = di.dishes_dish_id
    GROUP BY d.dish_id, d.name
)
SELECT dish_name
FROM dish_weight
WHERE rnk = 1;

--2
SELECT d.name AS dish_name
FROM public.dishes d
JOIN public.dishes_ingridients di
    ON d.dish_id = di.dishes_dish_id
JOIN public.ingridients i
    ON i.ingridient_id = di.ingridients_ingridient_id
GROUP BY d.dish_id, d.name
HAVING
    COUNT(*) = COUNT(
        CASE
            WHEN i.short_description IN ('Мука пшеничная', 'Яйцо куриное', 'Сахар')
            THEN 1
        END
    )
    AND COUNT(DISTINCT i.short_description) = 3;

