SELECT 
    a.name_albom AS "Альбом",
    c.name AS "Композиция",
    e.full_name AS "Исполнитель"
FROM public.composition c
JOIN public.albom a ON c.id_albom = a.id
JOIN public.executor_composition ec ON c.id = ec.id_composition
JOIN public.executor e ON ec.id_executor = e.id
ORDER BY a.name_albom, c.name;

SELECT 
    a.name_albom AS "Альбом",
    COUNT(c.id) AS "Треков с несколькими исполнителями"
FROM public.albom a
JOIN public.composition c ON a.id = c.id_albom
JOIN public.executor_composition ec ON c.id = ec.id_composition
GROUP BY  a.name_albom, c.id
HAVING COUNT(ec.id_executor) > 1;


WITH AlbumDurations AS (
    SELECT id_albom, SUM(duration_sec) AS total_time
    FROM public.composition
    GROUP BY id_albom
),
Shortest AS (
    SELECT id_albom FROM AlbumDurations ORDER BY total_time ASC LIMIT 1
),
Longest AS (
    SELECT id_albom FROM AlbumDurations ORDER BY total_time DESC LIMIT 1
)
UPDATE public.composition
SET id_albom = (SELECT id_albom FROM Longest)
WHERE id_albom = (SELECT id_albom FROM Shortest);

