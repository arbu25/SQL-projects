-- Проверка: SELECT * FROM public.albom; (Пустого альбома там больше не будет)


WITH TrackCounts AS (
    SELECT id_albom, COUNT(id) AS track_count
    FROM public.composition
    WHERE duration_sec > 180
    GROUP BY id_albom
)
SELECT a.name_albom AS "Альбом", tc.track_count AS "Кол-во длинных треков"
FROM TrackCounts tc
JOIN public.albom a ON tc.id_albom = a.id
WHERE tc.track_count = (SELECT MAX(track_count) FROM TrackCounts);

