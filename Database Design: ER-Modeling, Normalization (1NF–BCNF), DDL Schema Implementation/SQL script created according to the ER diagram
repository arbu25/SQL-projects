DROP TABLE IF EXISTS public.composition CASCADE;
DROP TABLE IF EXISTS public.albom CASCADE;
DROP TABLE IF EXISTS public.executor CASCADE;
DROP TABLE IF EXISTS public.ganre CASCADE;

CREATE TABLE IF NOT EXISTS public.ganre
(
    id integer NOT NULL,
    name_ganre character varying NOT NULL,
    PRIMARY KEY (id),
    CONSTRAINT name_ganre_unique UNIQUE (name_ganre),
    CONSTRAINT ganre_id_pos CHECK (id > 0),
    CONSTRAINT ganre_name_not_empty CHECK (length(trim(name_ganre)) > 0)
);

CREATE TABLE IF NOT EXISTS public.executor
(
    id integer NOT NULL,
    full_name character varying NOT NULL,
    type character varying NOT NULL,
    description text NOT NULL,
    id_ganre integer NOT NULL,
    PRIMARY KEY (id),
    CONSTRAINT full_name_unique UNIQUE (full_name),
    CONSTRAINT exec_id_pos CHECK (id > 0),
    CONSTRAINT exec_name_not_empty CHECK (length(trim(full_name)) > 0),
    CONSTRAINT exec_type_check CHECK (type IN ('Solo', 'Group', 'Band', 'Orchestra'))
);

CREATE TABLE IF NOT EXISTS public.albom
(
    id integer NOT NULL,
    name_albom character varying NOT NULL,
    id_ganre integer NOT NULL,
    PRIMARY KEY (id),
    CONSTRAINT name_albom_unique UNIQUE (name_albom),
    CONSTRAINT albom_id_pos CHECK (id > 0),
    CONSTRAINT albom_name_not_empty CHECK (length(trim(name_albom)) > 0)
);

CREATE TABLE IF NOT EXISTS public.composition
(
    id integer NOT NULL,
    name character varying NOT NULL,
    id_executor integer NOT NULL,
    id_albom integer NOT NULL,
    id_ganre integer NOT NULL,
    PRIMARY KEY (id),
    CONSTRAINT composition_name_unique UNIQUE (name),
    CONSTRAINT comp_id_pos CHECK (id > 0),
    CONSTRAINT comp_name_not_empty CHECK (length(trim(name)) > 0)
);

-- Добавляем внешние ключи с проверкой валидности
