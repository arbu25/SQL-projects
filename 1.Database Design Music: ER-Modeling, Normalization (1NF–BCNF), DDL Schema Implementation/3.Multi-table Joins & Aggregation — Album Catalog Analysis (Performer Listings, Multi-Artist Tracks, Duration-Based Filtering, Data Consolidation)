--(начало)выполнение запроса №1

SELECT
    a.name_albom AS "Альбом",
    c.name AS "Композиция",
    e.full_name AS "Исполнитель"
FROM public.albom a
JOIN public.composition c ON c.id_albom = a.id
JOIN public.executor_composition ec ON ec.id_composition = c.id
JOIN public.executor e ON e.id = ec.id_executor
ORDER BY a.name_albom, c.name, e.full_name;

--(конец)выполнение запроса №1

--(начало)выполнение запроса №2

WITH performer_counts AS (
    SELECT id_composition, COUNT(*) AS performer_count
    FROM public.executor_composition
    GROUP BY id_composition
)
SELECT
    a.name_albom AS "Альбом",
    COUNT(pc.id_composition) AS "Треков с несколькими исполнителями"
FROM public.albom a
LEFT JOIN public.composition c ON c.id_albom = a.id
LEFT JOIN performer_counts pc
    ON pc.id_composition = c.id AND pc.performer_count > 1
GROUP BY a.name_albom
ORDER BY a.name_albom;

--(конец)выполнение запроса №2

--(начало)выполнение запроса №3

WITH long_tracks AS (
    SELECT id_albom, COUNT(*) AS long_count
    FROM public.composition
    WHERE duration_sec > 180
    GROUP BY id_albom
)
SELECT
    a.name_albom AS "Альбом",
    lt.long_count AS "Кол-во треков длиннее 3 минут"
FROM long_tracks lt
JOIN public.albom a ON a.id = lt.id_albom
WHERE lt.long_count = (SELECT MAX(long_count) FROM long_tracks);

--(конец)выполнение запроса №3

--(начало)выполнение запроса №4

WITH album_durations AS (
    SELECT id_albom, SUM(duration_sec) AS total_duration
    FROM public.composition
    GROUP BY id_albom
),
shortest AS (
    SELECT id_albom FROM album_durations ORDER BY total_duration ASC LIMIT 1
),
longest AS (
    SELECT id_albom FROM album_durations ORDER BY total_duration DESC LIMIT 1
)
UPDATE public.composition
SET id_albom = (SELECT id_albom FROM longest)
WHERE id_albom = (SELECT id_albom FROM shortest);

--(конец)выполнение запроса №4

