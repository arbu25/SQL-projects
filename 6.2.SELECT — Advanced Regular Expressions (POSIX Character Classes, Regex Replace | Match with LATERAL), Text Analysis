##(начало)выполнение запроса №2

SELECT
    w.id,
    w.ln,
    w.fn,
    array_agg((m)[1]) AS names
FROM workers w,
LATERAL regexp_matches(
    regexp_replace(w.links_description, '(^|[.!?]\s+)([А-ЯЁ][а-яё]*)', '\1', 'g'),
    '[А-ЯЁ][а-яё]*',
    'g'
) AS m
GROUP BY w.id, w.ln, w.fn;

##(конец)выполнение запроса №2

##(начало)выполнение запроса №3

SELECT
    ln,
    fn,
    LENGTH(second_half) - LENGTH(REGEXP_REPLACE(second_half, '[А-ЯЁ]', '', 'g')) AS upper_count
FROM (
    SELECT
        ln,
        fn,
        SUBSTRING(work_description FROM (LENGTH(work_description) / 2 + 1)) AS second_half
    FROM workers
) t;


##(конец)выполнение запроса №3

##(начало)выполнение запроса №4

SELECT *
FROM (
    SELECT
        w.*,
        LENGTH(work_description) - LENGTH(REGEXP_REPLACE(work_description, '[[:punct:]]', '', 'g')) AS punct_count,
        LENGTH(work_description) - LENGTH(REGEXP_REPLACE(work_description, '[[:space:]]', '', 'g')) AS space_count
    FROM workers w
) t
WHERE punct_count * 2 <= space_count;


